    {"id": 1, "role": "dev", "task": "Create docker-compose.yml", "file": "apps/wedding-platform/docker-compose.yml", "instructions": "Create docker-compose.yml with services: postgres (postgres:16-alpine, port 5432, volume, env vars from .env), redis (redis:7-alpine, port 6379), backend (build ./backend, port 8000, depends_on postgres+redis, env_file .env, volumes for code, command: sh -c 'python manage.py migrate && python manage.py runserver 0.0.0.0:8000'), frontend (build ./frontend, port 3000, depends_on backend, env_file .env). Add volumes: postgres_data. Add networks: wedding_net.", "done_when": "docker-compose.yml exists and is valid YAML", "rf": ["RNF03"], "status": "completed"},
    {"id": 2, "role": "dev", "task": "Create backend Dockerfile", "file": "apps/wedding-platform/backend/Dockerfile", "instructions": "Create Dockerfile: FROM python:3.12-slim. WORKDIR /app. ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1. RUN apt-get update && apt-get install -y gcc libpq-dev && rm -rf /var/lib/apt/lists/*. COPY requirements.txt . RUN pip install --no-cache-dir -r requirements.txt. COPY . . EXPOSE 8000.", "done_when": "Dockerfile exists", "rf": ["RNF03"], "status": "completed"},
