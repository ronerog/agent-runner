# Dependencies
node_modules/
.next/
out/
build/
dist/

# Database
*.db
*.db-journal

# Environment and Secrets
.env
*.local
.gemini/*.json
.gemini/*.key

# Workspace / Per-project directories (generated per project, never committed)
# Ignora qualquer pasta de projeto em workspace/ (nome dinâmico)
# Mantém apenas memory/ e requirements/ que têm regras próprias abaixo
/workspace/*
!/workspace/memory/
!/workspace/requirements/
/workspace/state.json

# Workspace / Legacy files
/workspace/requirements/*
!/workspace/requirements/global_instructions.md

# Workspace / Memory (keep only global files)
/workspace/memory/*
!/workspace/memory/global.md
!/workspace/memory/agent-brain.md

# Tools and Editor files
.DS_Store
Thumbs.db
.claude/settings.local.json
.claude/worktrees/
